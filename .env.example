# Required Environment Variables for EI System
# Copy this to .env and fill in your values

# OpenAI API Key (Required)
OPENAI_API_KEY =  

# Embedding Model (Default: text-embedding-3-large)
embedding_model_name = text-embedding-3-large

# Generation Model (Default: gpt-4o-mini)
generation_model_name = gpt-4o-mini

# FAISS Index Path (Default: faiss_index)
FAISS_INDEX_PATH = faiss_index

# Interview Files Directory (Optional - defaults to files/interview_2)
# INTERVIEW_FILES_DIR=/path/to/interview/files
